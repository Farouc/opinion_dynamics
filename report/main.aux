\@writefile{toc}{\contentsline {subsection}{\numberline {4.5}Experiment 1 --- Convergence and time series}{8}{subsection.4.5}\protected@file@percent }
\@writefile{lof}{\contentsline {figure}{\numberline {3}{\ignorespaces Magnetization trajectories on BA N=500 for equal camp sizes under two placement strategies. Hub placement for the positive camp accelerates convergence and shifts trajectories upward, while random placement exhibits slower drift and weaker directional bias. This directly visualizes the dynamical advantage associated with controlling high-degree nodes.}}{8}{figure.caption.4}\protected@file@percent }
\newlabel{fig:exp1_ba_timeseries_pair}{{3}{8}{Magnetization trajectories on BA N=500 for equal camp sizes under two placement strategies. Hub placement for the positive camp accelerates convergence and shifts trajectories upward, while random placement exhibits slower drift and weaker directional bias. This directly visualizes the dynamical advantage associated with controlling high-degree nodes}{figure.caption.4}{}}
\newlabel{fig:exp1_ba_timeseries_pair@cref}{{[figure][3][]3}{[1][8][]8}}
\@writefile{lof}{\contentsline {figure}{\numberline {4}{\ignorespaces Convergence comparison across strategy pairs on BA N=500 in regime B. Placing positive zealots on high-degree nodes reduces characteristic convergence time by roughly one order of magnitude relative to random placement. This effect is a direct consequence of interaction frequency being proportional to incident degree under asynchronous updates.}}{9}{figure.caption.5}\protected@file@percent }
\newlabel{fig:exp1_convergence_comparison}{{4}{9}{Convergence comparison across strategy pairs on BA N=500 in regime B. Placing positive zealots on high-degree nodes reduces characteristic convergence time by roughly one order of magnitude relative to random placement. This effect is a direct consequence of interaction frequency being proportional to incident degree under asynchronous updates}{figure.caption.5}{}}
\newlabel{fig:exp1_convergence_comparison@cref}{{[figure][4][]4}{[1][8][]9}}
\@writefile{lof}{\contentsline {figure}{\numberline {5}{\ignorespaces Small-network snapshot grid for asynchronous voter updates with two zealot camps. Colors indicate committed and free-node opinions, and node size scales with degree. The sequence illustrates how local hub influence quickly seeds coherent opinion domains that later dominate global magnetization.}}{9}{figure.caption.6}\protected@file@percent }
\newlabel{fig:exp1_small_snapshots}{{5}{9}{Small-network snapshot grid for asynchronous voter updates with two zealot camps. Colors indicate committed and free-node opinions, and node size scales with degree. The sequence illustrates how local hub influence quickly seeds coherent opinion domains that later dominate global magnetization}{figure.caption.6}{}}
\newlabel{fig:exp1_small_snapshots@cref}{{[figure][5][]5}{[1][9][]9}}
\@writefile{toc}{\contentsline {subsection}{\numberline {4.6}Experiment 2 --- Phase diagram and tipping boundary}{10}{subsection.4.6}\protected@file@percent }
\@writefile{lof}{\contentsline {figure}{\numberline {6}{\ignorespaces BA phase diagrams of positive win probability in the (n\_plus, n\_minus) plane. Under random-vs-random placement, the transition follows a conventional boundary near balance. Under highest-degree placement for the positive camp, the winning region expands dramatically into minority territory, indicating strong structural compensation.}}{10}{figure.caption.7}\protected@file@percent }
\newlabel{fig:exp2_phase_ba}{{6}{10}{BA phase diagrams of positive win probability in the (n\_plus, n\_minus) plane. Under random-vs-random placement, the transition follows a conventional boundary near balance. Under highest-degree placement for the positive camp, the winning region expands dramatically into minority territory, indicating strong structural compensation}{figure.caption.7}{}}
\newlabel{fig:exp2_phase_ba@cref}{{[figure][6][]6}{[1][9][]10}}
\@writefile{lof}{\contentsline {figure}{\numberline {7}{\ignorespaces ER phase diagrams of positive win probability. The random baseline is close to symmetric around n\_plus equals n\_minus, while degree-based placement shifts the boundary toward smaller positive counts. Compared with BA, the shift is significant but less extreme, reflecting lower structural heterogeneity.}}{11}{figure.caption.8}\protected@file@percent }
\newlabel{fig:exp2_phase_er}{{7}{11}{ER phase diagrams of positive win probability. The random baseline is close to symmetric around n\_plus equals n\_minus, while degree-based placement shifts the boundary toward smaller positive counts. Compared with BA, the shift is significant but less extreme, reflecting lower structural heterogeneity}{figure.caption.8}{}}
\newlabel{fig:exp2_phase_er@cref}{{[figure][7][]7}{[1][10][]11}}
\@writefile{lof}{\contentsline {figure}{\numberline {8}{\ignorespaces Tipping-boundary overlays (P\_plus\_win = 0.5) for BA and ER graphs. Boundary displacement quantifies a strategic exchange rate between placement quality and zealot count. The BA contour is pushed farthest toward low n\_plus, demonstrating that scale-free hubs amplify the advantage of informed placement.}}{12}{figure.caption.9}\protected@file@percent }
\newlabel{fig:exp2_boundary_overlay}{{8}{12}{Tipping-boundary overlays (P\_plus\_win = 0.5) for BA and ER graphs. Boundary displacement quantifies a strategic exchange rate between placement quality and zealot count. The BA contour is pushed farthest toward low n\_plus, demonstrating that scale-free hubs amplify the advantage of informed placement}{figure.caption.9}{}}
\newlabel{fig:exp2_boundary_overlay@cref}{{[figure][8][]8}{[1][11][]12}}
\@writefile{lof}{\contentsline {figure}{\numberline {9}{\ignorespaces Crossing-time heatmap near the ER tipping region for highest-degree versus random placement. Cells close to P\_plus\_win approximately 0.5 display markedly longer first-crossing times, a numerical signature of critical slowing down. This supports a phase-transition interpretation of the competition boundary.}}{13}{figure.caption.10}\protected@file@percent }
\newlabel{fig:exp2_crossing_time}{{9}{13}{Crossing-time heatmap near the ER tipping region for highest-degree versus random placement. Cells close to P\_plus\_win approximately 0.5 display markedly longer first-crossing times, a numerical signature of critical slowing down. This supports a phase-transition interpretation of the competition boundary}{figure.caption.10}{}}
\newlabel{fig:exp2_crossing_time@cref}{{[figure][9][]9}{[1][12][]13}}
\@writefile{toc}{\contentsline {subsection}{\numberline {4.7}Experiment 3 --- WL placement: a counter-intuitive result}{14}{subsection.4.7}\protected@file@percent }
\@writefile{lof}{\contentsline {figure}{\numberline {10}{\ignorespaces Strategy comparison for WL experiment settings. Highest-degree and WL-top-class strategies dominate, while WL-cover underperforms and can fail completely. This counter-intuitive ranking highlights the mismatch between structural uniqueness and dynamic influence in imitation processes.}}{14}{figure.caption.11}\protected@file@percent }
\newlabel{fig:exp3_strategy_bars}{{10}{14}{Strategy comparison for WL experiment settings. Highest-degree and WL-top-class strategies dominate, while WL-cover underperforms and can fail completely. This counter-intuitive ranking highlights the mismatch between structural uniqueness and dynamic influence in imitation processes}{figure.caption.11}{}}
\newlabel{fig:exp3_strategy_bars@cref}{{[figure][10][]10}{[1][13][]14}}
\@writefile{lof}{\contentsline {figure}{\numberline {11}{\ignorespaces ER structural-feature scatter matrix relating strategy-level features to positive win probability. Degree-normalized strength tracks performance positively, while dispersion exhibits a strong negative relation. The pattern supports the mechanism that concentrated influence around high-degree cores beats diffuse placement.}}{15}{figure.caption.12}\protected@file@percent }
\newlabel{fig:exp3_feature_scatter}{{11}{15}{ER structural-feature scatter matrix relating strategy-level features to positive win probability. Degree-normalized strength tracks performance positively, while dispersion exhibits a strong negative relation. The pattern supports the mechanism that concentrated influence around high-degree cores beats diffuse placement}{figure.caption.12}{}}
\newlabel{fig:exp3_feature_scatter@cref}{{[figure][11][]11}{[1][14][]15}}
\@writefile{toc}{\contentsline {subsection}{\numberline {4.8}Experiment 4 --- Effective strength metrics and the order parameter}{16}{subsection.4.8}\protected@file@percent }
\@writefile{lof}{\contentsline {figure}{\numberline {12}{\ignorespaces Win-probability versus ratio\_psi\_degree\_norm across all graph families and configurations. A steep logistic transition appears near 0.5, indicating a sharp switch between negative and positive dominance. This metric therefore acts as an empirical order parameter for two-camp voter competition.}}{16}{figure.caption.13}\protected@file@percent }
\newlabel{fig:exp4_metric_scatter}{{12}{16}{Win-probability versus ratio\_psi\_degree\_norm across all graph families and configurations. A steep logistic transition appears near 0.5, indicating a sharp switch between negative and positive dominance. This metric therefore acts as an empirical order parameter for two-camp voter competition}{figure.caption.13}{}}
\newlabel{fig:exp4_metric_scatter@cref}{{[figure][12][]12}{[1][15][]16}}
\@writefile{lof}{\contentsline {figure}{\numberline {13}{\ignorespaces AUC comparison of candidate normalized metrics by graph family. Degree-normalized and PageRank-based ratios dominate globally, while WL-only and dispersion-only metrics lag. The ranking demonstrates that influence capacity is primarily controlled by access to high-degree channels.}}{16}{figure.caption.14}\protected@file@percent }
\newlabel{fig:exp4_auc_summary}{{13}{16}{AUC comparison of candidate normalized metrics by graph family. Degree-normalized and PageRank-based ratios dominate globally, while WL-only and dispersion-only metrics lag. The ranking demonstrates that influence capacity is primarily controlled by access to high-degree channels}{figure.caption.14}{}}
\newlabel{fig:exp4_auc_summary@cref}{{[figure][13][]13}{[1][16][]16}}
\@writefile{lof}{\contentsline {figure}{\numberline {14}{\ignorespaces Critical-band and minority-dominance diagnostics in effective-strength space. The left panel shows concentration of near-transition points around ratio\_psi\_degree\_norm approximately 0.5. The right panel isolates minority-win BA cases, where structural advantage shifts the minority camp deep into the winning regime.}}{17}{figure.caption.15}\protected@file@percent }
\newlabel{fig:exp4_critical_minority}{{14}{17}{Critical-band and minority-dominance diagnostics in effective-strength space. The left panel shows concentration of near-transition points around ratio\_psi\_degree\_norm approximately 0.5. The right panel isolates minority-win BA cases, where structural advantage shifts the minority camp deep into the winning regime}{figure.caption.15}{}}
\newlabel{fig:exp4_critical_minority@cref}{{[figure][14][]14}{[1][16][]17}}
