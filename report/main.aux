\@writefile{lof}{\contentsline {figure}{\numberline {18}{\ignorespaces Representative FC, ER, and BA topologies with identical zealot counts under highest-degree placement. Node sizes indicate degree, making visible the dramatic hub concentration in BA. The visual contrast clarifies why the same placement policy has weak impact on FC and large impact on BA.}}{20}{figure.caption.20}\protected@file@percent }
\newlabel{fig:exp5_network_visuals}{{18}{20}{Representative FC, ER, and BA topologies with identical zealot counts under highest-degree placement. Node sizes indicate degree, making visible the dramatic hub concentration in BA. The visual contrast clarifies why the same placement policy has weak impact on FC and large impact on BA}{figure.caption.20}{}}
\newlabel{fig:exp5_network_visuals@cref}{{[figure][18][]18}{[1][19][]20}}
\@writefile{lof}{\contentsline {figure}{\numberline {19}{\ignorespaces Cross-family comparison of structural metrics under highest-degree placement. The degree-normalized strength term is largest where placement advantage is largest, supporting the interpretation that degree control is the primary mechanism of dominance.}}{20}{figure.caption.21}\protected@file@percent }
\newlabel{fig:exp5_struct_metrics}{{19}{20}{Cross-family comparison of structural metrics under highest-degree placement. The degree-normalized strength term is largest where placement advantage is largest, supporting the interpretation that degree control is the primary mechanism of dominance}{figure.caption.21}{}}
